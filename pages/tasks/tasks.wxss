.tasks-page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 28rpx 24rpx 48rpx;
  background:
    radial-gradient(circle at top, #fff4d9 0%, #fffdf7 34%, #ffeede 100%);
}

.tasks-hero {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding: 32rpx 28rpx;
  border-radius: 32rpx;
  background: linear-gradient(135deg, #fff8de 0%, #ffe6c9 100%);
  box-shadow: 0 20rpx 48rpx rgba(210, 157, 68, 0.12);
  color: #6b4d1f;
}

.tasks-hero__emoji {
  font-size: 44rpx;
}

.tasks-hero__title {
  font-size: 38rpx;
  font-weight: 700;
}

.tasks-hero__date {
  font-size: 24rpx;
  color: #9a7b49;
}

.tasks-hero__summary {
  font-size: 26rpx;
  line-height: 1.6;
  color: #7d6237;
}

.tasks-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-top: 24rpx;
}

.tasks-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 28rpx 24rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 16rpx 40rpx rgba(210, 157, 68, 0.1);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.tasks-item.is-clickable:active {
  transform: scale(0.98);
}

.tasks-item.is-locked {
  opacity: 0.88;
}

.tasks-item__main {
  display: flex;
  align-items: center;
  gap: 18rpx;
  min-width: 0;
  flex: 1;
}

.tasks-item__icon {
  width: 72rpx;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 22rpx;
  background: #fff5dc;
  text-align: center;
  font-size: 36rpx;
  flex-shrink: 0;
}

.tasks-item__content {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  min-width: 0;
}

.tasks-item__label {
  font-size: 32rpx;
  font-weight: 700;
  color: #5b4323;
}

.tasks-item__helper {
  font-size: 24rpx;
  color: #967b52;
}

.tasks-item__aside {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 12rpx;
  flex-shrink: 0;
}

.tasks-item__points {
  font-size: 24rpx;
  color: #af8345;
}

.tasks-item__badge {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.tasks-item__badge-icon {
  font-size: 24rpx;
}

.tasks-item__badge-label {
  line-height: 1;
}

.tasks-item__badge.is-todo,
.tasks-item.is-todo {
  background-color: #ffffff;
}

.tasks-item__badge.is-todo {
  color: #8b7250;
  background: #f6efe7;
}

.tasks-item__badge.is-pending {
  color: #9c6217;
  background: #fff1cb;
}

.tasks-item.is-pending {
  background: #fffaf0;
}

.tasks-item__badge.is-approved {
  color: #2e7a47;
  background: #dff4e5;
}

.tasks-item.is-approved {
  background: #f6fffa;
}

.tasks-item__badge.is-rejected {
  color: #b74855;
  background: #ffe0e4;
}

.tasks-item.is-rejected {
  background: #fff7f8;
}

.tasks-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  margin-top: 24rpx;
  padding: 72rpx 32rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.92);
  text-align: center;
  box-shadow: 0 20rpx 48rpx rgba(210, 157, 68, 0.08);
}

.tasks-empty__emoji {
  font-size: 56rpx;
}

.tasks-empty__title {
  font-size: 32rpx;
  font-weight: 700;
  color: #5f4422;
}

.tasks-empty__desc {
  font-size: 26rpx;
  line-height: 1.6;
  color: #957651;
}
