.tasks-page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 28rpx 24rpx 48rpx;
  padding-bottom: 166rpx;
  padding-bottom: calc(166rpx + env(safe-area-inset-bottom));
  background:
    radial-gradient(circle at top, #fff4d9 0%, #fffdf7 34%, #ffeede 100%);
}

.tasks-hero {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding: 32rpx 28rpx;
  border-radius: 32rpx;
  background: linear-gradient(135deg, #fff8de 0%, #ffe6c9 100%);
  box-shadow: 0 20rpx 48rpx rgba(210, 157, 68, 0.12);
  color: #6b4d1f;
}

.tasks-hero__emoji {
  font-size: 44rpx;
}

.tasks-hero__title {
  font-size: 38rpx;
  font-weight: 700;
}

.tasks-hero__date {
  font-size: 24rpx;
  color: #9a7b49;
}

.tasks-hero__summary {
  font-size: 26rpx;
  line-height: 1.6;
  color: #7d6237;
}

.tasks-list {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
  margin-top: 24rpx;
}

.tasks-section {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.tasks-section__head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 0 8rpx;
}

.tasks-section__title {
  font-size: 28rpx;
  font-weight: 700;
  color: #6b4d1f;
}

.tasks-section__count {
  font-size: 22rpx;
  color: #9a7b49;
}

.tasks-section__list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.tasks-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  margin-top: 24rpx;
  padding: 72rpx 32rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.92);
  text-align: center;
  box-shadow: 0 20rpx 48rpx rgba(210, 157, 68, 0.08);
}

.tasks-empty__emoji {
  font-size: 56rpx;
}

.tasks-empty__title {
  font-size: 32rpx;
  font-weight: 700;
  color: #5f4422;
}

.tasks-empty__desc {
  font-size: 26rpx;
  line-height: 1.6;
  color: #957651;
}
