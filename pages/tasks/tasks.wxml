<view class="tasks-page">
  <view class="tasks-hero">
    <text class="tasks-hero__emoji">📋</text>
    <text class="tasks-hero__title">现在先做最重要的一件事</text>
    <text class="tasks-hero__date">{{currentDate}}</text>
    <text class="tasks-hero__summary">
      待打卡 {{todoCount}} · 待确认 {{pendingCount}} · 已完成 {{approvedCount}}
    </text>
  </view>

  <view wx:if="{{taskCount > 0}}" class="tasks-list">
    <view wx:if="{{nowTasks.length > 0}}" class="tasks-section">
      <view class="tasks-section__head">
        <text class="tasks-section__title">现在去做</text>
        <text class="tasks-section__count">{{nowTasks.length}} 项</text>
      </view>
      <view class="tasks-section__list">
        <task-card
          wx:for="{{nowTasks}}"
          wx:key="id"
          task="{{item}}"
          highlighted="{{item.id === recommendedTaskId}}"
          bind:taptask="handleTaskTap"
        />
      </view>
    </view>

    <view wx:if="{{laterTasks.length > 0}}" class="tasks-section">
      <view class="tasks-section__head">
        <text class="tasks-section__title">今天稍后</text>
        <text class="tasks-section__count">{{laterTasks.length}} 项</text>
      </view>
      <view class="tasks-section__list">
        <task-card
          wx:for="{{laterTasks}}"
          wx:key="id"
          task="{{item}}"
          bind:taptask="handleTaskTap"
        />
      </view>
    </view>

    <view wx:if="{{doneTasks.length > 0}}" class="tasks-section">
      <view class="tasks-section__head">
        <text class="tasks-section__title">已经完成</text>
        <text class="tasks-section__count">{{doneTasks.length}} 项</text>
      </view>
      <view class="tasks-section__list">
        <task-card
          wx:for="{{doneTasks}}"
          wx:key="id"
          task="{{item}}"
          bind:taptask="handleTaskTap"
        />
      </view>
    </view>
  </view>

  <view wx:else class="tasks-empty">
    <text class="tasks-empty__emoji">🫧</text>
    <text class="tasks-empty__title">今天没有可打卡任务</text>
    <text class="tasks-empty__desc">家长还没有开启任务，先回去陪陪宠物吧。</text>
  </view>
</view>
