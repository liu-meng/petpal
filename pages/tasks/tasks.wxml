<view class="tasks-page">
  <view class="tasks-hero">
    <text class="tasks-hero__emoji">📋</text>
    <text class="tasks-hero__title">今天也认真完成任务吧</text>
    <text class="tasks-hero__date">{{currentDate}}</text>
    <text class="tasks-hero__summary">
      待打卡 {{todoCount}} · 待确认 {{pendingCount}} · 已完成 {{approvedCount}}
    </text>
  </view>

  <view wx:if="{{taskCount > 0}}" class="tasks-list">
    <view
      wx:for="{{tasks}}"
      wx:key="id"
      class="tasks-item {{item.badgeClass}} {{item.canCheckin ? 'is-clickable' : 'is-locked'}}"
      data-task-id="{{item.id}}"
      bindtap="handleTaskTap"
    >
      <view class="tasks-item__main">
        <text class="tasks-item__icon">{{item.icon}}</text>
        <view class="tasks-item__content">
          <text class="tasks-item__label">{{item.label}}</text>
          <text class="tasks-item__helper">{{item.helperText}}</text>
        </view>
      </view>

      <view class="tasks-item__aside">
        <text class="tasks-item__points">+{{item.points}}分</text>
        <view class="tasks-item__badge {{item.badgeClass}}">
          <text class="tasks-item__badge-icon">{{item.badgeIcon}}</text>
          <text class="tasks-item__badge-label">{{item.badgeLabel}}</text>
        </view>
      </view>
    </view>
  </view>

  <view wx:else class="tasks-empty">
    <text class="tasks-empty__emoji">🫧</text>
    <text class="tasks-empty__title">今天没有可打卡任务</text>
    <text class="tasks-empty__desc">家长还没有开启任务，先回去陪陪宠物吧。</text>
  </view>
</view>
