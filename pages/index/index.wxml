<view class="index-page">
  <view class="index-header">
    <view class="index-title">
      <text class="index-title__emoji">🐕</text>
      <text class="index-title__name">{{petName}}</text>
    </view>
    <text class="index-header__period">{{recommendedTaskLabel ? '现在先做' : '今天陪伴中'}}</text>
  </view>

  <view class="index-card index-pet-card">
    <view class="index-pet-stage-meta">
      <view class="index-mood-badge">{{moodLabel}}</view>
      <text class="index-mood-hint">{{moodHint}}</text>
    </view>
    <view class="index-pet-avatar">
      <pet-avatar
        id="petAvatar"
        species="{{pet.type}}"
        mood="{{mood}}"
        hunger="{{pet.hunger}}"
        happiness="{{pet.happiness}}"
        size="420"
        enableAnimation="{{petAnimationEnabled}}"
        bind:pettap="handlePetTap"
        bind:petlongpress="handlePetLongPress"
        bind:actionstart="handlePetActionStart"
        bind:actionend="handlePetActionEnd"
      />
      <text
        wx:if="{{statFloatVisible}}"
        class="index-float-text index-float-text--stat"
      >{{statFloatText}}</text>
    </view>
    <view class="index-bubble">{{bubbleText}}</view>
  </view>

  <view class="index-card index-mission-card" bindtap="handleGoTasks">
    <view class="index-mission-card__head">
      <text class="index-mission-card__eyebrow">当前任务</text>
      <text class="index-mission-card__cta">去看看 ›</text>
    </view>
    <text class="index-mission-card__title">
      {{recommendedTaskLabel ? recommendedTaskLabel : '今天先看看要做什么'}}
    </text>
    <text class="index-mission-card__desc">
      {{pendingTaskCount > 0 ? '还有 ' + pendingTaskCount + ' 个任务在等你，先做最合适的一件吧！' : '今天的主要任务都完成啦，回来陪陪它吧。'}}
    </text>
  </view>

  <view class="index-card index-stats-card">
    <stat-bar
      icon="🍖"
      label="饱食度"
      value="{{pet.hunger}}"
      max="10"
      color="#ffb24d"
    />
    <stat-bar
      icon="💛"
      label="快乐值"
      value="{{pet.happiness}}"
      max="10"
      color="#ff82a3"
    />
  </view>

  <view class="index-points-card index-card">
    <text class="index-points-card__label">💰 积分</text>
    <text class="index-points-card__value">{{points}} 分</text>
    <text
      wx:if="{{pointsFloatVisible}}"
      class="index-float-text index-float-text--points"
    >{{pointsFloatText}}</text>
  </view>

  <view class="index-actions">
    <action-btn
      icon="🍖"
      label="喂食"
      cost-label="-1分"
      action="feed"
      disabled="{{feedDisabled}}"
      bindtapaction="handleActionTap"
    />
    <action-btn
      icon="🎾"
      label="玩耍"
      cost-label="-1分"
      action="play"
      disabled="{{playDisabled}}"
      bindtapaction="handleActionTap"
    />
  </view>

  <view class="index-touch-hint">
    <text class="index-touch-hint__icon">🤲</text>
    <text class="index-touch-hint__text">轻点或长按宠物就能摸摸它</text>
  </view>
</view>
