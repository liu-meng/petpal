<view class="index-page">
  <!-- 顶部栏：压缩，宠物名+等级+积分 -->
  <view class="index-topbar">
    <view class="index-topbar__left">
      <text class="index-topbar__emoji">🐕</text>
      <text class="index-topbar__name">{{petName}}</text>
    </view>
    <view class="index-topbar__right">
      <text class="index-topbar__level">Lv{{petLevel}}</text>
      <text class="index-topbar__stars">⭐{{starCount}}</text>
    </view>
  </view>

  <!-- 宠物主视觉区（核心） -->
  <view class="index-pet-zone">
    <!-- 情绪标签 + 提示 -->
    <view class="index-pet-meta">
      <view class="index-mood-badge">{{moodLabel}}</view>
      <text class="index-mood-hint">{{moodHint}}</text>
    </view>

    <!-- 宠物头像（放大） -->
    <view class="index-pet-avatar">
      <pet-avatar
        id="petAvatar"
        species="{{pet.type}}"
        mood="{{mood}}"
        hunger="{{pet.hunger}}"
        happiness="{{pet.happiness}}"
        size="520"
        enableAnimation="{{petAnimationEnabled}}"
        bind:pettap="handlePetTap"
        bind:petlongpress="handlePetLongPress"
        bind:actionstart="handlePetActionStart"
        bind:actionend="handlePetActionEnd"
      />
      <text
        wx:if="{{statFloatVisible}}"
        class="index-float-text index-float-text--stat"
      >{{statFloatText}}</text>
    </view>

    <!-- 宠物气泡文案（情绪化） -->
    <view class="index-bubble">{{bubbleText}}</view>
  </view>

  <!-- 主 CTA 按钮：去完成任务 -->
  <view
    wx:if="{{recommendedTaskLabel}}"
    class="index-cta"
    hover-class="index-cta--pressing"
    bindtap="handleGoTasks"
  >
    <text class="index-cta__icon">🎯</text>
    <text class="index-cta__text">{{recommendedTaskLabel}}</text>
    <text class="index-cta__arrow">›</text>
  </view>
  <view
    wx:else
    class="index-cta index-cta--done"
    hover-class="index-cta--pressing"
    bindtap="handleGoTasks"
  >
    <text class="index-cta__icon">✨</text>
    <text class="index-cta__text">今天任务都完成啦！</text>
    <text class="index-cta__arrow">›</text>
  </view>

  <!-- 状态条（紧凑两行） -->
  <view class="index-stats-row">
    <view class="index-stat-item">
      <view class="index-stat-item__header">
        <text class="index-stat-item__icon">🍖</text>
        <text class="index-stat-item__label">饱食度</text>
        <text class="index-stat-item__value">{{pet.hunger}}/10</text>
      </view>
      <view class="index-stat-item__track">
        <view class="index-stat-item__fill" style="width: {{pet.hunger * 10}}%; background: #F5C451;"></view>
      </view>
    </view>
    <view class="index-stat-item">
      <view class="index-stat-item__header">
        <text class="index-stat-item__icon">💛</text>
        <text class="index-stat-item__label">快乐值</text>
        <text class="index-stat-item__value">{{pet.happiness}}/10</text>
      </view>
      <view class="index-stat-item__track">
        <view class="index-stat-item__fill" style="width: {{pet.happiness * 10}}%; background: #FF7DA8;"></view>
      </view>
    </view>
  </view>

  <!-- 快捷互动按钮（轻量化圆形） -->
  <view class="index-quick-actions">
    <view
      class="index-quick-btn {{feedDisabled ? 'is-disabled' : ''}}"
      hover-class="{{feedDisabled ? '' : 'index-quick-btn--pressing'}}"
      bindtap="handleFeedTap"
    >
      <text class="index-quick-btn__icon">🍖</text>
      <text class="index-quick-btn__label">喂食</text>
    </view>
    <view
      class="index-quick-btn {{playDisabled ? 'is-disabled' : ''}}"
      hover-class="{{playDisabled ? '' : 'index-quick-btn--pressing'}}"
      bindtap="handlePlayTap"
    >
      <text class="index-quick-btn__icon">🎾</text>
      <text class="index-quick-btn__label">玩耍</text>
    </view>
    <view
      class="index-quick-btn"
      hover-class="index-quick-btn--pressing"
      bindtap="handlePetQuickTap"
    >
      <text class="index-quick-btn__icon">🤚</text>
      <text class="index-quick-btn__label">抚摸</text>
    </view>
  </view>

  <!-- 积分浮动提示 -->
  <text
    wx:if="{{pointsFloatVisible}}"
    class="index-float-text index-float-text--points"
  >{{pointsFloatText}}</text>
</view>
