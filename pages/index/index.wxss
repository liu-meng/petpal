.index-page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 28rpx 24rpx 48rpx;
  background:
    radial-gradient(circle at top, #fff7dc 0%, #fffdf8 36%, #fff4e2 100%);
}

.index-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.index-title {
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-width: 0;
}

.index-title__emoji {
  font-size: 38rpx;
}

.index-title__name {
  font-size: 40rpx;
  font-weight: 700;
  color: #5f4218;
}

.index-header__period {
  display: inline-flex;
  align-items: center;
  min-height: 52rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  background: rgba(255, 244, 216, 0.92);
  color: #9f6a1a;
  font-size: 24rpx;
  font-weight: 700;
}

.index-card {
  border-radius: 34rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 20rpx 48rpx rgba(210, 157, 68, 0.12);
}

.index-pet-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
  padding: 32rpx 24rpx 28rpx;
}

.index-pet-stage-meta {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.index-mood-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 48rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 700;
  background: rgba(255, 186, 87, 0.18);
  color: #d87419;
}

.index-mood-hint {
  flex: 1;
  min-width: 0;
  text-align: right;
  font-size: 22rpx;
  color: #9b7d4f;
}

.index-pet-avatar {
  position: relative;
  min-height: 440rpx;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  width: 100%;
  overflow: hidden;
}

.index-bubble {
  width: 100%;
  box-sizing: border-box;
  padding: 24rpx 28rpx;
  border-radius: 28rpx;
  background: #fff6df;
  text-align: center;
  font-size: 28rpx;
  line-height: 1.6;
  color: #7a5d2c;
}

.index-mission-card {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin-top: 20rpx;
  padding: 28rpx 24rpx;
  background: linear-gradient(135deg, #fff8d7 0%, #ffe8bd 100%);
}

.index-mission-card__head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.index-mission-card__eyebrow {
  font-size: 22rpx;
  font-weight: 700;
  color: #af7420;
  letter-spacing: 2rpx;
}

.index-mission-card__cta {
  font-size: 22rpx;
  color: #8f7142;
}

.index-mission-card__title {
  font-size: 36rpx;
  font-weight: 700;
  color: #5d4121;
}

.index-mission-card__desc {
  font-size: 24rpx;
  line-height: 1.6;
  color: #80643a;
}

.index-stats-card {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
  margin-top: 20rpx;
  padding: 28rpx 24rpx;
}

.index-points-card {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 20rpx;
  padding: 28rpx 24rpx;
  border-radius: 30rpx;
  background: linear-gradient(135deg, #fff4c7 0%, #ffe09b 100%);
  color: #6e4f1e;
  overflow: hidden;
}

.index-points-card__label {
  font-size: 26rpx;
  font-weight: 600;
}

.index-points-card__value {
  font-size: 34rpx;
  font-weight: 700;
}

.index-float-text {
  position: absolute;
  left: 50%;
  pointer-events: none;
  white-space: nowrap;
  transform: translateX(-50%);
  animation-duration: 1.4s;
  animation-timing-function: ease-out;
  animation-fill-mode: forwards;
}

.index-float-text--stat {
  top: 16rpx;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.92);
  color: #ff7f50;
  font-size: 24rpx;
  font-weight: 700;
  box-shadow: 0 12rpx 24rpx rgba(255, 156, 112, 0.16);
  animation-name: index-float-up-center;
}

.index-float-text--points {
  right: 28rpx;
  left: auto;
  top: 18rpx;
  color: #d97b1f;
  font-size: 24rpx;
  font-weight: 700;
  transform: translateY(0);
  animation-name: index-float-up-right;
}

.index-actions {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 24rpx;
}

.index-touch-hint {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  margin-top: 18rpx;
  color: #8b7250;
  font-size: 24rpx;
}

.index-touch-hint__icon {
  font-size: 26rpx;
}

@keyframes index-float-up-center {
  0% {
    opacity: 0;
    transform: translateX(-50%) translateY(12rpx) scale(0.94);
  }

  20% {
    opacity: 1;
  }

  100% {
    opacity: 0;
    transform: translateX(-50%) translateY(-42rpx) scale(1.04);
  }
}

@keyframes index-float-up-right {
  0% {
    opacity: 0;
    transform: translateY(12rpx) scale(0.94);
  }

  20% {
    opacity: 1;
  }

  100% {
    opacity: 0;
    transform: translateY(-42rpx) scale(1.04);
  }
}
