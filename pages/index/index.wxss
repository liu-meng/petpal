/* ========================================
   PetPal 首页 V1 重构
   设计原则：一屏显示 · 宠物中心化 · 情绪驱动
   配色：暖米黄 #F6E7B4 / 强调 #F4B183 / 快乐粉 #FF7DA8 / 饱食黄 #F5C451
   ======================================== */

.index-page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 16rpx 24rpx 20rpx;
  background:
    radial-gradient(circle at top, #fff7dc 0%, #fffdf8 36%, #fff4e2 100%);
  display: flex;
  flex-direction: column;
}

/* ====== 顶部栏（压缩）====== */
.index-topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 56rpx;
  margin-bottom: 8rpx;
  flex-shrink: 0;
}

.index-topbar__left {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.index-topbar__emoji {
  font-size: 34rpx;
}

.index-topbar__name {
  font-size: 34rpx;
  font-weight: 700;
  color: #5f4218;
}

.index-topbar__right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.index-topbar__level {
  font-size: 24rpx;
  font-weight: 700;
  color: #fff;
  background: #F4B183;
  padding: 2rpx 14rpx;
  border-radius: 999rpx;
}

.index-topbar__stars {
  font-size: 24rpx;
  font-weight: 600;
  color: #9f6a1a;
}

/* ====== 宠物主视觉区（核心）====== */
.index-pet-zone {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
  position: relative;
}

.index-pet-meta {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  margin-bottom: 4rpx;
}

.index-mood-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 44rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
  background: rgba(255, 186, 87, 0.18);
  color: #d87419;
}

.index-mood-hint {
  flex: 1;
  min-width: 0;
  text-align: right;
  font-size: 20rpx;
  color: #9b7d4f;
}

.index-pet-avatar {
  position: relative;
  width: 100%;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  overflow: hidden;
}

.index-bubble {
  width: 100%;
  box-sizing: border-box;
  padding: 14rpx 24rpx;
  border-radius: 24rpx;
  background: #fff6df;
  text-align: center;
  font-size: 26rpx;
  line-height: 1.5;
  color: #7a5d2c;
  margin-top: 6rpx;
}

/* ====== 主 CTA 按钮 ===== */
.index-cta {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  height: 64rpx;
  margin-top: 12rpx;
  border-radius: 32rpx;
  background: linear-gradient(135deg, #F6E7B4 0%, #F4B183 100%);
  box-shadow: 0 8rpx 28rpx rgba(244, 177, 131, 0.35);
  transition: transform 120ms ease, box-shadow 120ms ease;
  flex-shrink: 0;
}

.index-cta--pressing {
  transform: scale(0.96);
  box-shadow: 0 4rpx 14rpx rgba(244, 177, 131, 0.25);
}

.index-cta--done {
  background: linear-gradient(135deg, #e8f5e0 0%, #a8d5a0 100%);
  box-shadow: 0 8rpx 28rpx rgba(168, 213, 160, 0.3);
}

.index-cta__icon {
  font-size: 30rpx;
}

.index-cta__text {
  font-size: 30rpx;
  font-weight: 700;
  color: #5d4121;
}

.index-cta__arrow {
  font-size: 32rpx;
  color: #8f7142;
  font-weight: 700;
}

/* ====== 状态条（紧凑两行）====== */
.index-stats-row {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-top: 14rpx;
  padding: 16rpx 20rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.85);
  box-shadow: 0 8rpx 24rpx rgba(210, 157, 68, 0.08);
  flex-shrink: 0;
}

.index-stat-item {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.index-stat-item__header {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.index-stat-item__icon {
  font-size: 22rpx;
}

.index-stat-item__label {
  font-size: 22rpx;
  font-weight: 600;
  color: #7a6038;
  flex: 1;
}

.index-stat-item__value {
  font-size: 22rpx;
  font-weight: 700;
  color: #5d4524;
}

.index-stat-item__track {
  height: 12rpx;
  border-radius: 6rpx;
  background: #f0e0c8;
  overflow: hidden;
}

.index-stat-item__fill {
  height: 100%;
  border-radius: 6rpx;
  transition: width 0.4s ease;
}

/* ====== 快捷互动按钮（轻量化圆形）====== */
.index-quick-actions {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 32rpx;
  margin-top: 14rpx;
  flex-shrink: 0;
}

.index-quick-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  width: 112rpx;
  height: 104rpx;
  border-radius: 50%;
  background: linear-gradient(180deg, #fff8e7 0%, #ffe7b4 100%);
  box-shadow: 0 8rpx 20rpx rgba(210, 157, 68, 0.14);
  transition: transform 120ms ease, box-shadow 120ms ease;
}

.index-quick-btn--pressing {
  transform: scale(0.92);
  box-shadow: 0 4rpx 10rpx rgba(210, 157, 68, 0.1);
}

.index-quick-btn.is-disabled {
  background: linear-gradient(180deg, #f1ece2 0%, #e1dacc 100%);
  box-shadow: none;
  opacity: 0.55;
}

.index-quick-btn__icon {
  font-size: 36rpx;
}

.index-quick-btn__label {
  font-size: 20rpx;
  font-weight: 700;
  color: #5d4524;
}

.index-quick-btn.is-disabled .index-quick-btn__label {
  color: #8d8371;
}

/* ====== 浮动提示文字 ===== */
.index-float-text {
  position: absolute;
  pointer-events: none;
  white-space: nowrap;
  animation-duration: 1.4s;
  animation-timing-function: ease-out;
  animation-fill-mode: forwards;
  z-index: 10;
}

.index-float-text--stat {
  left: 50%;
  top: 20%;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.92);
  color: #ff7f50;
  font-size: 24rpx;
  font-weight: 700;
  box-shadow: 0 12rpx 24rpx rgba(255, 156, 112, 0.16);
  transform: translateX(-50%);
  animation-name: index-float-up-center;
}

.index-float-text--points {
  right: 32rpx;
  bottom: 220rpx;
  color: #d97b1f;
  font-size: 24rpx;
  font-weight: 700;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 8rpx 16rpx rgba(217, 123, 31, 0.15);
  transform: translateY(0);
  animation-name: index-float-up-right;
}

@keyframes index-float-up-center {
  0% {
    opacity: 0;
    transform: translateX(-50%) translateY(12rpx) scale(0.94);
  }
  20% { opacity: 1; }
  100% {
    opacity: 0;
    transform: translateX(-50%) translateY(-42rpx) scale(1.04);
  }
}

@keyframes index-float-up-right {
  0% {
    opacity: 0;
    transform: translateY(12rpx) scale(0.94);
  }
  20% { opacity: 1; }
  100% {
    opacity: 0;
    transform: translateY(-42rpx) scale(1.04);
  }
}
