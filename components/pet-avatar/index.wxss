.pet-avatar {
  position: relative;
  display: block;
  overflow: visible;
  background: transparent;
}

.pet-avatar__stage {
  position: absolute;
  inset: 0;
  background: transparent;
  pointer-events: none;
}

.pet-avatar__canvas,
.pet-avatar__fallback-image,
.pet-avatar__empty {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.pet-avatar__canvas,
.pet-avatar__fallback-image {
  pointer-events: none;
}

.pet-avatar__fallback-image {
  box-sizing: border-box;
}

.pet-avatar__empty {
  display: flex;
  align-items: center;
  justify-content: center;
  color: rgba(110, 77, 39, 0.68);
  font-size: 24rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
}
