<view class="tab-bar">
  <view class="tab-bar__dock">
    <view
      wx:for="{{list}}"
      wx:key="index"
      class="tab-bar__item {{index === 1 ? 'is-home' : ''}} {{selected === index ? 'is-active' : ''}} {{item.hasDot ? 'has-dot' : ''}} {{item.needsCare ? 'needs-care' : ''}}"
      data-path="{{item.pagePath}}"
      data-index="{{index}}"
      bindtap="switchTab"
      animation="{{animations[index]}}"
    >
      <!-- 角标 -->
      <view wx:if="{{item.badge > 0}}" class="tab-bar__badge">
        <text class="tab-bar__badge-text">{{item.badge > 99 ? '99+' : item.badge}}</text>
      </view>

      <view wx:if="{{item.hasDot && item.badge <= 0}}" class="tab-bar__dot"></view>

      <view class="tab-bar__icon-shell">
        <image
          class="tab-bar__icon {{selected === index ? 'is-active' : ''}}"
          src="{{selected === index ? item.selectedIconPath : item.iconPath}}"
          mode="aspectFit"
        />
      </view>

      <!-- 文字 -->
      <text class="tab-bar__text">{{item.text}}</text>
    </view>
  </view>
</view>
