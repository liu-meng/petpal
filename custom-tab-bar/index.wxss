/* custom-tab-bar/index.wxss */
/* 自定义 TabBar - 童趣风格 */

.tab-bar {
  display: flex;
  align-items: flex-end;
  justify-content: center;
  height: 150rpx;
  padding: 0 24rpx calc(14rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background: transparent;
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 999;
}

.tab-bar__dock {
  position: relative;
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  justify-content: space-around;
  width: 100%;
  height: 112rpx;
  padding: 8rpx 10rpx 0;
  box-sizing: border-box;
  background: rgba(255, 255, 250, 0.98);
  border: 1rpx solid rgba(238, 226, 204, 0.92);
  border-radius: 36rpx;
  box-shadow:
    0 -4rpx 14rpx rgba(99, 72, 42, 0.06),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.95);
  overflow: visible;
}

.tab-bar__item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  flex: 1;
  height: 100%;
  padding-top: 2rpx;
  box-sizing: border-box;
  position: relative;
  overflow: visible; /* 允许图标放大后溢出 */
  border-radius: 28rpx 28rpx 0 0;
  z-index: 2;
}

.tab-bar__item:active {
  transform: scale(0.92);
}

.tab-bar__item.is-active {
  background: transparent;
}

.tab-bar__item.is-home {
  transform: translateY(-18rpx);
}

.tab-bar__item.is-home:active {
  transform: translateY(-18rpx) scale(0.94);
}

.tab-bar__item.is-home.is-active {
  background: transparent;
}

.tab-bar__item.needs-care .tab-bar__icon-shell {
  animation: care-shake 1.1s ease-in-out infinite;
}

.tab-bar__icon-shell {
  width: 92rpx;
  height: 92rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  transition: background-color 0.24s ease, box-shadow 0.24s ease, transform 0.24s ease;
}

.tab-bar__item.is-active .tab-bar__icon-shell {
  background: #FFF2DF;
  border: 1rpx solid rgba(255, 203, 144, 0.9);
  box-shadow: 0 4rpx 10rpx rgba(255, 140, 66, 0.1);
}

.tab-bar__item.is-home .tab-bar__icon-shell {
  width: 112rpx;
  height: 112rpx;
}

.tab-bar__item.is-home.is-active .tab-bar__icon-shell {
  background: #FFF1DC;
  border: 1rpx solid rgba(255, 196, 126, 0.95);
  box-shadow: 0 6rpx 14rpx rgba(255, 140, 66, 0.12);
}

.tab-bar__icon {
  width: 188rpx;
  height: 188rpx;
  transition: all 0.25s ease;
  transform-origin: center center;
}

.tab-bar__item.is-home .tab-bar__icon {
  width: 216rpx;
  height: 216rpx;
}

/* 选中态：放大 + 跳动动画 */
.tab-bar__icon.is-active {
  width: 196rpx;
  height: 196rpx;
  animation: icon-bounce 0.4s ease;
}

.tab-bar__item.is-home .tab-bar__icon.is-active {
  width: 224rpx;
  height: 224rpx;
}

.tab-bar__item.needs-care .tab-bar__icon.is-active {
  animation: icon-bounce 0.4s ease;
}

@keyframes icon-bounce {
  0% {
    transform: scale(1.0);
  }
  40% {
    transform: scale(1.25);
  }
  70% {
    transform: scale(1.1);
  }
  100% {
    transform: scale(1.15);
  }
}

.tab-bar__text {
  margin-top: -2rpx;
  font-size: 16rpx;
  color: #B5A68C;
  line-height: 1.2;
  transition: color 0.3s ease;
}

.tab-bar__item.is-active .tab-bar__text {
  color: #FF8C42;
  font-weight: 600;
  font-size: 17rpx;
}

.tab-bar__item.is-home .tab-bar__text {
  margin-top: -5rpx;
}

/* 角标：家长 tab 待审核数量 */
.tab-bar__badge {
  position: absolute;
  top: 6rpx;
  right: 50%;
  margin-right: -42rpx;
  min-width: 28rpx;
  height: 28rpx;
  padding: 0 6rpx;
  border-radius: 14rpx;
  background-color: #FF6B6B;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10;
  box-shadow: 0 2rpx 4rpx rgba(255, 107, 107, 0.4);
}

.tab-bar__badge-text {
  font-size: 16rpx;
  color: #FFFFFF;
  font-weight: 600;
  line-height: 1;
}

/* 轻提示：任务 tab 当前有可打卡任务 */
.tab-bar__dot {
  position: absolute;
  top: 12rpx;
  right: 50%;
  margin-right: -40rpx;
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background-color: #FFD166;
  box-shadow: 0 0 0 6rpx rgba(255, 209, 102, 0.22);
}

.tab-bar__item.has-dot .tab-bar__icon-shell {
  box-shadow: 0 0 0 4rpx rgba(255, 209, 102, 0.1);
}

@keyframes care-shake {
  0%, 100% {
    transform: rotate(0deg);
  }
  24% {
    transform: rotate(-4deg);
  }
  48% {
    transform: rotate(4deg);
  }
  72% {
    transform: rotate(-2deg);
  }
}
